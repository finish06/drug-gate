{
  "$schema": "https://github.com/MountainUnicorn/add/config.schema.json",
  "version": "0.5.0",
  "project": {
    "name": "drug-gate",
    "description": "Public-facing Go microservice gateway that provides frontend applications with drug information (name, therapeutic class, interactions) by querying the internal cash-drugs API cache/proxy. Handles auth, rate limiting, NDC normalization, and data transformation.",
    "created": "2026-03-07",
    "author": "calebdunn"
  },
  "maturity": {
    "level": "alpha",
    "promoted_from": null,
    "promoted_date": null,
    "next_promotion_criteria": "Feature specs for all user-facing features, test coverage above 50%, PR workflow with code review, TDD evidence"
  },
  "architecture": {
    "languages": [
      {
        "name": "Go",
        "version": "1.26",
        "role": "backend"
      }
    ],
    "backend": {
      "framework": "chi",
      "version": "v5",
      "runtime": "Go 1.26"
    },
    "frontend": {
      "framework": null,
      "version": null,
      "bundler": "none"
    },
    "database": {
      "type": "Redis",
      "version": "latest"
    },
    "containerized": true,
    "container_strategy": "docker-compose",
    "suggested_by_claude": false
  },
  "infrastructure": {
    "git_host": "github",
    "git_remote": "github.com/finish06/drug-gate",
    "cloud_provider": "self-hosted",
    "cloud_services": [],
    "cicd": {
      "platform": "github-actions",
      "scaffolded_by_add": true,
      "pipeline_file": ".github/workflows/ci.yml"
    },
    "infrastructure_as_code": "none"
  },
  "environments": {
    "tier": 3,
    "local": {
      "run": "docker-compose up",
      "test": "go test ./...",
      "e2e": "go test ./tests/e2e/...",
      "url": "http://localhost:8081"
    },
    "dev": {
      "deploy_trigger": null,
      "url": null,
      "verify": ["unit_tests"]
    },
    "staging": {
      "deploy_trigger": "push to main (beta image)",
      "url": "http://192.168.1.145:8082",
      "verify": ["unit_tests", "integration_tests", "e2e"],
      "deploy_path": "/opt/drug-gate/",
      "host": "192.168.1.145"
    },
    "production": {
      "deploy_trigger": "merge to main",
      "verify": ["smoke_tests"],
      "url": "https://drug-gate.calebdunn.tech",
      "requires_approval": true
    }
  },
  "quality": {
    "mode": "standard",
    "coverage_threshold": 80,
    "type_check_blocking": true,
    "e2e_required": false,
    "screenshot_protocol": false,
    "lint": {
      "backend": "golangci-lint run ./...",
      "frontend": null
    },
    "typecheck": {
      "backend": "go vet ./...",
      "frontend": null
    },
    "test": {
      "unit": "go test ./... -short",
      "integration": "go test ./... -run Integration",
      "e2e": "go test ./tests/e2e/..."
    }
  },
  "collaboration": {
    "autonomy_level": "autonomous",
    "team_size": "small-team",
    "commit_review_gate": false,
    "pr_review_gate": true,
    "deploy_approval_required": true
  },
  "source_control": {
    "branching": "feature-branches",
    "default_branch": "main",
    "commit_convention": "conventional",
    "pr_template": true,
    "protected_branches": ["main"]
  },
  "branding": {
    "accentColor": "#0891b2",
    "presetName": "ocean",
    "palette": {
      "accent": "#0891b2",
      "accentLight": "#22d3ee",
      "accentDark": "#0e7490",
      "accentMuted": "#67e8f9",
      "accentGlow": "rgba(8,145,178,0.4)",
      "gradientStart": "#0891b2",
      "gradientMid": "#06b6d4",
      "gradientEnd": "#22d3ee",
      "success": "#22c55e",
      "warning": "#eab308",
      "info": "#0ea5e9"
    },
    "fonts": null,
    "tone": null,
    "logoPath": null,
    "styleGuideSource": null
  },
  "imageGeneration": {
    "enabled": false,
    "tool": null,
    "plugin": null,
    "nudged": false,
    "lastDetected": null
  },
  "changelog": {
    "lastProcessedCommit": "0388e6b024d4cb8503997dc7ff1ffc7a503bb9ef",
    "lastVersionTag": "v0.5.0"
  },
  "planning": {
    "current_milestone": null,
    "current_cycle": null,
    "wip_limit": 3,
    "parallel_agents": 1,
    "cycle_history": []
  }
}
